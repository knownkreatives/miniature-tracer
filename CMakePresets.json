{
    "version": 8,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "GCC 6.3.0 mingw32",
            "description": "Using compilers: C = C:\\Libraries\\MinGW\\bin\\gcc.exe, CXX = C:\\Libraries\\MinGW\\bin\\g++.exe",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "environment": {
                "VCPKG_ROOT": "vcpkg_export"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "C:/Libraries/MinGW/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "C:/Libraries/MinGW/bin/g++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}